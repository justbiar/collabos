# ─── WalletConnect Project ID (required for Web3Modal) ───────────────────────
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# ─── Deployed Contract Addresses (set after running deploy script) ────────────
NEXT_PUBLIC_SQUADHUB_ADDRESS=0xYOUR_SQUADHUB_ADDRESS
NEXT_PUBLIC_STREAMGRANT_ADDRESS=0xYOUR_STREAMGRANT_ADDRESS

# ─── Oracle API URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ORACLE_API_URL=http://localhost:8000

# ─── Monad Testnet RPC ───────────────────────────────────────────────────────
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
